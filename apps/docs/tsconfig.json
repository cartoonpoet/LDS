{
  "extends": "../../packages/typescript-config/react-library.json",
  "compilerOptions": {
    "baseUrl": ".",
    "allowJs": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": [
      "dom",
      "dom.iterable",
      "es2020"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@lds/ui-v3": [
        "../../packages/ui-v3/src"
      ],
      "@lds/tokens": [
        "../../packages/tokens/src"
      ]
    },
    "resolveJsonModule": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mdx",
    ".next/types/**/*.ts",
    "mdx-components.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
