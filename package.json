{
  "name": "lds-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.20.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "check": "turbo run check",
    "test": "turbo run test",
    "storybook": "turbo run storybook --filter=@lds/storybook"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.3"
  }
}
