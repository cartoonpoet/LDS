{
  "name": "lds-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.20.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --ui=tui",
    "build": "turbo run build --ui=tui",
    "lint": "turbo run lint --ui=tui",
    "check": "turbo run check --ui=tui",
    "test": "turbo run test --ui=tui",
    "storybook": "turbo run storybook --filter=@lds/storybook --ui=tui"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.3"
  }
}
